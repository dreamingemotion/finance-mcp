# URL of the ibkr-agent server — if running on the same host, localhost is correct
IBKR_AGENT_URL=http://localhost:8000

# Secret token Claude uses to authenticate with this MCP server.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
MCP_API_KEY=

# MCP server bind settings
MCP_HOST=0.0.0.0
MCP_PORT=8080
